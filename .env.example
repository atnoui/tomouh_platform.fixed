# ── Supabase (tomouh_project) ──────────────────────────────────────────────
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://behftzxktknfkbqindck.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY, never exposed to the browser.
# Used only by the admin-signup server action to create admin accounts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Admin signup ───────────────────────────────────────────────────────────
# Whoever knows this key can register as an Admin. Keep it secret, rotate it
# if it ever leaks, and only share it with people you trust to administer
# the platform.
ADMIN_SIGNUP_KEY=choose-a-long-random-secret

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
